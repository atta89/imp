# HTTP server
PORT=8080
APP_BASE_URL=http://localhost:8080

# Public host of the web app. QR codes encode FRONTEND_BASE_URL/scan/<token>
# so a phone camera scan opens the user-facing page, not the API JSON.
# Falls back to APP_BASE_URL if unset.
FRONTEND_BASE_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=imp

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Gmail SMTP (use an App Password, NOT your normal Gmail password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Logging: debug | info | warn | error
LOG_LEVEL=info

# First-run admin seed. If no admin user exists at startup AND both of these are
# set, the server creates one. Safe to leave unset after the first boot.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# Cron expression for the daily overdue scan (server local time, robfig/cron
# 5-field format). Default: every day at 09:00.
OVERDUE_CRON=0 9 * * *

# Optional path to a PNG/JPEG to use as the QR center logo. Leave empty to use
# the embedded default (internal/qr/assets/logo.png).
QR_LOGO_PATH=

# Async bulk-asset jobs. All five bulk endpoints enqueue a job and return 202;
# an in-process worker executes them in batched Mongo transactions.
BULK_MAX_ASSETS=5000            # max assetIds per request (deduped at enqueue)
BULK_BATCH_SIZE=100             # assets per transaction
BULK_WORKER_CONCURRENCY=1       # in-process claim/run goroutines
BULK_WORKER_POLL_INTERVAL=5s    # idle poll cadence
BULK_JOB_LEASE_SECONDS=120      # worker lease; expired leases are reclaimed
BULK_JOB_MAX_ATTEMPTS=5         # per-batch retry cap before rows are errored
BULK_JOB_ERROR_CAP=1000         # max row errors retained per job
BULK_RESULT_TTL_DAYS=7          # retention for rendered QR PDFs
BULK_RESULT_CLEANUP_CRON=0 4 * * *  # daily deletion of expired job results
